# praxis-aegis environment — copy to .env and fill in before starting

PORT=8080

# Paths (defaults to project root locations if unset)
# POLICY_PATH=./tool_risk_tier.yaml
# ALLOWED_SIGNERS_DIR=./allowed_signers

# Comma-separated identities allowed to perform control-plane reloads
# ADMIN_IDENTITIES=daedalus

# HMAC secret for gateway-to-backend assertions (min 32 chars)
BACKEND_ASSERTION_SECRET=

# REQUIRED: HMAC secret for signing/verifying caller tokens (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALLER_HMAC_SECRET=

# REQUIRED: JWT secret for session tokens (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_JWT_SECRET=

# Session lifetime in hours (default: 8)
SESSION_TTL_HOURS=8

# How long a challenge nonce is valid in seconds (default: 300 = 5 min)
CHALLENGE_TTL_SECONDS=300

# Max challenge requests per IP per minute (default: 10)
RATE_LIMIT_CHALLENGE_PER_MIN=10

# Optional: backend service URLs — uncomment and register routes in server.ts
# SEARCH_SERVICE_URL=http://localhost:8081
# DATA_SERVICE_URL=http://localhost:8082
